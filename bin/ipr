#!/usr/bin/env python3

import argparse

parser = argparse.ArgumentParser(
    prog="Invoke Prime", description="Returns answers for invoke prime calls."
)
parser.add_argument("-d", "--debug", action="store_true")
parser.add_argument("-f", "--fix", action="store_true")
parser.add_argument("-l", "--line", default=None)
parser.add_argument("-m", "--mob", default=None)
parser.add_argument("-p", "--puzzle", default=None)
parser.add_argument("-s", "--school", default=None)
args = parser.parse_args()

# TODO: should we have a word list and a phrase list?  more important for
# mob matching
word_list = open("bin/ipr_words.txt").read().split("\n")


def debug(msg: str):
    if args.debug:
        print(msg)


def find_word(word: str, word_list: list[str], split: bool = True) -> str:
    debug(f"find word: {word}")
    new_word = []
    words = [word.lower()]
    if split:
        words = map(str.lower, word.split(" "))

    for word in words:
        found = False
        debug(f"checking {word}")
        for _word in word_list:
            debug(f"  against {_word}")
            if len(word) != len(_word):
                continue

            for i, c in enumerate(word):
                if i == len(word) - 1:
                    debug("  found!")
                    found = True
                if c == "-":
                    continue
                if c != _word[i]:
                    break
            if found:
                break
        if found:
            new_word.append(_word)
    debug(f"new_word is now {new_word}")
    return " ".join(new_word)


def fix_word_list() -> None:
    word_list = sorted(list(set(open("bin/ipr_words.txt").read().split("\n"))))
    with open("bin/ipr_words.txt", "w") as f:
        for word in word_list:
            f.write(f"{word}\n")


if args.fix:
    print("Sorting and deduping word list")
    fix_word_list()
    print("Done")
    exit(0)

solution = ""
line = args.line

# swap school for placeholder if school is passed
if args.school:
    line = line.replace("&2", find_word(args.school, word_list))

# swap mob for placeholder if mob is passed
if args.mob:
    # try to find the whole mob phrase first
    if found := find_word(args.mob, word_list, False):
        line = line.replace("&2", found)
    else:
        line = line.replace("&2", find_word(args.mob, word_list))

debug(line)
debug(args.puzzle)
for i, c in enumerate(args.puzzle):
    if c == "-":
        solution += line[i]
print(solution)

# test cases

